---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} — Alan Tapper`} description={project.data.description}>
  <article>
    <header class="mb-10">
      <h1 class="text-2xl font-semibold">{project.data.title}</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 mb-4">{project.data.description}</p>

      <ul class="flex flex-wrap gap-2 mb-4">
        {project.data.tech.map((t) => (
          <li class="text-xs text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800 rounded px-2 py-1">{t}</li>
        ))}
      </ul>

      <div class="flex gap-4 text-sm">
        {project.data.url && (
          <a href={project.data.url} class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" target="_blank" rel="noopener">
            Live →
          </a>
        )}
        {project.data.repo && (
          <a href={project.data.repo} class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" target="_blank" rel="noopener">
            GitHub →
          </a>
        )}
      </div>
    </header>

    <div class="prose prose-gray dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>

  <a href="/projects" class="mt-12 inline-block text-sm text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors">
    ← Back to projects
  </a>
</Base>
