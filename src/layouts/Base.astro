---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-white text-gray-900 antialiased">
    <div class="mx-auto max-w-2xl px-6 py-12">
      <header class="mb-16">
        <nav class="flex items-center justify-between">
          <a href="/" class="text-sm font-medium hover:text-gray-500 transition-colors">
            Alan Tapper
          </a>
          <ul class="flex gap-6 text-sm text-gray-500">
            <li><a href="/about" class="hover:text-gray-900 transition-colors">About</a></li>
            <li><a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a></li>
            <li><a href="/blog" class="hover:text-gray-900 transition-colors">Blog</a></li>
          </ul>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="mt-24 border-t border-gray-100 pt-8 text-sm text-gray-400">
        <p>© {new Date().getFullYear()} Alan Tapper</p>
      </footer>
    </div>
  </body>
</html>
